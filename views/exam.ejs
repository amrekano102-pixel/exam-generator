<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= exam ? exam.title : 'الامتحان غير موجود' %> - مولد الامتحانات</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .student-info { background: #f0f7ff; border: 1px solid #d0e5ff; border-radius: 10px; padding: 18px; margin-bottom: 20px; }
    .student-info label { font-weight: 600; color: #2c3e50; margin-bottom: 8px; }
    .student-info input { width: 100%; padding: 10px 14px; border: 2px solid #d0e5ff; border-radius: 8px; font-size: 1em; }
    .student-info input:focus { outline: none; border-color: #3498db; }
  </style>
</head>
<body>
  <%- include('partials/ad', { position: 'top-page' }) %>

  <div class="container">
    <%- include('partials/ad', { position: 'exam-top' }) %>
    <% if (exam) { %>
      <header>
        <h1><%= exam.title %></h1>
        <p>أجب عن الأسئلة التالية</p>
      </header>

      <% if (!submitted) { %>
        <form id="answerForm">
          <div class="student-info">
            <label>👤 اسم الطالب</label>
            <input type="text" id="studentName" placeholder="أدخل اسمك" required>
          </div>

          <% exam.questions.forEach(function(q, i) { %>
            <div class="question-item exam-mode">
              <div class="question-header">
                <span class="question-number">السؤال <%= i + 1 %></span>
              </div>
              <p class="question-text-display"><%= q.text %></p>

              <% if (q.type === 'mcq' && q.options.length > 0) { %>
                <div class="options-exam">
                  <% q.options.forEach(function(opt) { %>
                    <label class="option-label">
                      <input type="radio" name="q_<%= q.id %>" value="<%= opt %>">
                      <span><%= opt %></span>
                    </label>
                  <% }); %>
                </div>
              <% } else if (q.type === 'truefalse') { %>
                <div class="options-exam">
                  <label class="option-label">
                    <input type="radio" name="q_<%= q.id %>" value="صح">
                    <span>صح</span>
                  </label>
                  <label class="option-label">
                    <input type="radio" name="q_<%= q.id %>" value="خطأ">
                    <span>خطأ</span>
                  </label>
                </div>
              <% } else { %>
                <textarea class="answer-textarea" name="q_<%= q.id %>" placeholder="اكتب إجابتك هنا..." rows="3"></textarea>
              <% } %>
            </div>
            <% if ((i + 1) % 3 === 0 && (i + 1) < exam.questions.length) { %>
              <%- include('partials/ad', { position: 'exam-between' }) %>
            <% } %>
          <% }); %>

          <button type="submit" class="btn-submit">✅ تأكيد الإجابات</button>
        </form>
      <% } %>

      <div id="result" class="result-box" style="display:<%= submitted ? 'block' : 'none' %>;">
        <h3>✅ تم استلام إجاباتك!</h3>
        <p>شكراً لك، تم تسليم إجاباتك بنجاح. سيتم إعلام منشئ الامتحان.</p>
      </div>
    <% } else { %>
      <header>
        <h1>❌ الامتحان غير موجود</h1>
        <p><%= error %></p>
        <a href="/" class="btn-submit" style="display:inline-block;text-decoration:none;margin-top:20px;">🏠 العودة للرئيسية</a>
      </header>
    <% } %>

    <%- include('partials/ad', { position: 'exam-after' }) %>
    <%- include('partials/ad', { position: 'bottom-page' }) %>
  </div>

  <% if (exam && !submitted) { %>
  <script>
    document.getElementById('answerForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const studentName = document.getElementById('studentName').value.trim();
      if (!studentName) { alert('الرجاء إدخال اسمك'); return; }

      const answers = [];
      <% exam.questions.forEach(function(q) { %>
        let answer = '';
        <% if (q.type === 'mcq' || q.type === 'truefalse') { %>
          const radio_<%= q.id %> = document.querySelector('input[name="q_<%= q.id %>"]:checked');
          answer = radio_<%= q.id %> ? radio_<%= q.id %>.value : '';
        <% } else { %>
          const text_<%= q.id %> = document.querySelector('textarea[name="q_<%= q.id %>"]');
          answer = text_<%= q.id %> ? text_<%= q.id %>.value.trim() : '';
        <% } %>
        answers.push({ questionId: <%= q.id %>, answer });
      <% }); %>

      const btn = this.querySelector('.btn-submit');
      btn.disabled = true;
      btn.textContent = 'جاري الإرسال...';

      try {
        const res = await fetch('/api/exams/<%= exam.id %>/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ studentName, answers })
        });
        if (!res.ok) throw new Error('فشل إرسال الإجابات');
        this.style.display = 'none';
        document.getElementById('result').style.display = 'block';
        document.getElementById('result').scrollIntoView({ behavior: 'smooth' });
      } catch (err) {
        alert('حدث خطأ: ' + err.message);
        btn.disabled = false;
        btn.textContent = '✅ تأكيد الإجابات';
      }
    });
  </script>
  <% } %>
</body>
</html>
